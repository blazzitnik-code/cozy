# ─── Next.js (copy into .env.local) ─────────────────────────────
# Local: URL and anon key are printed by `npx supabase status` (API_URL / ANON_KEY).
# Production: values from the Supabase dashboard (Settings → API).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth client ID — used by the in-app Google Calendar connection.
# Same client as the Supabase Google login (Google Cloud Console → Credentials).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# JCDecaux API key for BicikeLJ stations (https://developer.jcdecaux.com)
NEXT_PUBLIC_BICIKELJ_API_KEY=your-jcdecaux-api-key

# Web push VAPID public key (base64url). Generate the pair once with
# `deno run supabase/functions/send-push/generate-keys.ts` and use the SAME
# pair locally and in prod. The private half (VAPID_KEYS_JSON) plus
# PUSH_FN_SECRET/VAPID_SUBJECT belong in supabase/functions/.env locally and
# `npx supabase secrets set` in prod — never in this file or the repo.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# ─── Supabase CLI (copy into .env at the project root) ───────────
# Used by supabase/config.toml for local Google login
# (env() substitution at `npx supabase start`).
SUPABASE_AUTH_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
SUPABASE_AUTH_GOOGLE_SECRET=your-google-client-secret
